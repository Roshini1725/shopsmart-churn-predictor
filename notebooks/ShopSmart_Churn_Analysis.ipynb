## 8. Business Recommendations

The model gives us probabilities — here's how a CRM team would act on them.
# Risk tiering on test set
results = X_test.copy()
results['actual_churn'] = y_test.values
results['xgb_churn_probability'] = xgb_proba
results['risk_tier'] = pd.cut(
    results['xgb_churn_probability'],
    bins=[0, 0.30, 0.60, 1.0],
    labels=['🟢 Low Risk', '🟡 Medium Risk', '🔴 High Risk']
)

tier_summary = results.groupby('risk_tier').agg(
    members=('actual_churn', 'count'),
    actual_churn_rate=('actual_churn', 'mean')
).reset_index()

tier_summary['actual_churn_rate'] = tier_summary['actual_churn_rate'].map('{:.1%}'.format)
print('=== CRM Risk Tier Summary ===')
print(tier_summary.to_string(index=False))
# CRM action framework
